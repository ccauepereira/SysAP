# Local development environment. Copy values into your shell or local tooling;
# the API does not load this file automatically.
SYSAP_ENV=development
SYSAP_HTTP_ADDR=:8080

# Optional in Phase 1A. Keep empty to run the API without PostgreSQL.
SYSAP_DATABASE_URL=

SYSAP_SHUTDOWN_TIMEOUT=10s
SYSAP_DATABASE_PING_TIMEOUT=2s
